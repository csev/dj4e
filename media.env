# Source before running media-util tools for DJ4E:
#   source /Users/csev/htdocs/dj4e/media.env

# ---------------------------------------------------------------------------
# Per-course settings (edit these when copying for another course)
# ---------------------------------------------------------------------------
export COURSE_ROOT=/Users/csev/htdocs/dj4e
export MEDIA_ROOT=/Users/csev/Desktop/teach/dj4e-media
export WHISPER_ROOT=/Users/csev/htdocs/dj4e/whisper
export YOUTUBE_DIR=/Users/csev/htdocs/dj4e/youtube
export YOUTUBE_PLAYLIST='https://www.youtube.com/playlist?list=PLlRFEj9H3Oj5e-EH0t3kXrcdygrL9-u-Z'
export COURSE_HINT='Django for Everybody, DJ4E, Django, Python, web development, Dr. Chuck, Chuck Severance'
export TITLE_PREFIX='DJ'
export EXTRA_TAGS='dj4e, dj4e-lecture'
export EXTRA_DESCRIPTION='For more materials, auto graders, and more courses, please see www.masterprogrammer.com.'

# Kaltura / MiVideo (UMSI ALI)
# Playlist: https://umsiali.mivideo.it.umich.edu/playlist/dedicated/410698932/1_6058dcqq
export KALTURA_PARTNER_ID=1038472
export KALTURA_SERVICE_URL='https://www.kaltura.com'
export KALTURA_PLAYLIST_ID='1_6058dcqq'
export KALTURA_PLAYLIST_URL='https://umsiali.mivideo.it.umich.edu/playlist/dedicated/410698932/1_6058dcqq'
export KALTURA_UICONF_ID=58045402
# Player embed used by Tsugi lessons (see tsugi_settings.php kaltura_embed); {id} = entry id
export KALTURA_EMBED='https://cdnapisec.kaltura.com/p/1038472/embedPlaykitJs/uiconf_id/58045402?iframeembed=true&entry_id={id}'
# Open-in-new-tab playlist URL (tsugi_settings.php kaltura_tab); {id} = entry id
export KALTURA_TAB='https://umsiali.mivideo.it.umich.edu/playlist/dedicated/410698932/1_6058dcqq/{id}'
# export KALTURA_CATEGORY_ID=           # MediaSpace / category folder id
# export KALTURA_USER_ID=media-util
# Admin secret: set env OR put one line in ~/.ssh/kaltura_admin_secret
# export KALTURA_ADMIN_SECRET='…'
# export KALTURA_SECRET_FILE=$HOME/.ssh/kaltura_admin_secret

# Optional per-course overrides:
# export MODEL=$HOME/models/ggml-medium.bin
# export OLLAMA_MODEL=qwen3:4b

# ---------------------------------------------------------------------------
# Shared boilerplate (usually leave alone)
# ---------------------------------------------------------------------------
PWD_NOW="$(pwd -P)"

case "$PWD_NOW" in
  "$COURSE_ROOT"|"$COURSE_ROOT"/*) ;;
  *)
    echo "ERROR: media.env is for this course; pwd is $PWD_NOW" >&2
    echo "       expected under $COURSE_ROOT" >&2
    return 1 2>/dev/null || exit 1
    ;;
esac

export MEDIA_UTIL=/Users/csev/htdocs/media-util
case ":$PATH:" in
  *":$MEDIA_UTIL/bin:"*) ;;
  *) export PATH="$MEDIA_UTIL/bin:$PATH" ;;
esac

echo "media.env: ready (pwd=$PWD_NOW); run media-help for common commands"
